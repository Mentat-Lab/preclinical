# =============================================================================
# Preclinical Environment Template
# =============================================================================
# Copy to .env and fill values required for your setup.

# =============================================================================
# Server Core
# =============================================================================
PORT=8000
NODE_ENV=development
DATABASE_URL=postgres://postgres:preclinical@localhost:5432/preclinical
# Used by docker-compose for the Postgres container
DB_PASSWORD=preclinical
VITE_API_URL=http://localhost:8000
LOG_LEVEL=info
LOG_FORMAT=pretty

# =============================================================================
# LLM Runtime
# =============================================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434/v1
# Model names: use "ollama:" prefix for Ollama (e.g., ollama:llama3.2)
TESTER_MODEL=ollama:llama3.2
TESTER_TEMPERATURE=0.2
GRADER_MODEL=ollama:llama3.2
GRADER_TEMPERATURE=0.1
WORKER_CONCURRENCY=5

# Turn limits (per scenario conversation)
DEFAULT_MAX_TURNS=6
MIN_MAX_TURNS=5
MAX_MAX_TURNS=7

# Per-turn intent analysis (benchmark mode)
ENABLE_TURN_INTENTS=true
TURN_INTENT_MODEL=gpt-4o-mini

# Graph timeouts (ms) — increase for slower LLMs like Ollama
PLANNING_TIMEOUT_MS=60000
TURN_TIMEOUT_MS=30000
COVERAGE_TIMEOUT_MS=60000
GRADING_TIMEOUT_MS=120000

# =============================================================================
# Provider Keys (optional by provider)
# =============================================================================
# BrowserUse: local worker (included in docker compose up)
# API key is optional for the local worker — leave empty unless your worker requires auth
BROWSER_USE_API_KEY=
BROWSER_USE_API_BASE=
# Browserbase: cloud Chrome instances (alternative to local Chrome pool)
# When set, CDP_URL is ignored and no 'make chrome' is needed.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# CDP mode (default): connects to real Chrome on your host.
# Required: launch Chrome before running docker compose up:
#   Mac:   open -a "Google Chrome" --args --remote-debugging-port=9222 --remote-allow-origins=*
#   Linux: google-chrome --remote-debugging-port=9222 --remote-allow-origins=*
# To use built-in headless Chromium instead (no CDP), comment out this line.
CDP_URL=http://host.docker.internal:9222
# Global browser login credentials (used when sites require auth)
# Can be overridden per-agent via config.email / config.password
BROWSER_STEP_TIMEOUT=60
BROWSER_MAX_ACTIONS_PER_STEP=5
BROWSER_USE_VISION=false
BROWSER_SAVE_CONVERSATIONS=false
BROWSER_GENERATE_GIFS=false
# Number of Chrome instances in the local pool (used by make chrome)
MAX_CHROME_INSTANCES=5
BROWSER_EMAIL=
BROWSER_PASSWORD=
AGENTMAIL_API_KEY=
VAPI_API_KEY=
TEST_VAPI_ASSISTANT_ID=

# =============================================================================
# LiveKit (required only when testing livekit provider)
# =============================================================================
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=
LIVEKIT_DISPATCH_MODE=explicit
LIVEKIT_ROOM_PREFIX=preclinical-test
LIVEKIT_TEXT_INTEGRATION_ID=
LIVEKIT_VOICE_INTEGRATION_ID=

# =============================================================================
# Pipecat (required only when testing pipecat provider)
# =============================================================================
PIPECAT_CLOUD_API_URL=https://api.pipecat.daily.co
PIPECAT_API_KEY=
PIPECAT_AGENT_NAME=
TEST_PIPECAT_AGENT_NAME=
PIPECAT_DOMAIN=

# =============================================================================
# Optional Integrations
# =============================================================================
DAILY_API_KEY=
CARTESIA_API_KEY=

# =============================================================================
# Tests (optional, for Vitest API test suite)
# =============================================================================
TEST_BASE_URL=http://localhost:8000
TEST_OPENAI_BASE_URL=https://api.openai.com/v1
TEST_OPENAI_API_KEY=
TEST_OPENAI_MODEL=gpt-4o-mini
