# Pipecat Agent Environment Variables
# Copy this to the repo root .env file

# OpenAI Configuration (required for LLM)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Override model name for gateways (e.g., TrueFoundry)
# OPENAI_MODEL=openai-main/gpt-4o-mini

# Cartesia Configuration (required for TTS)
CARTESIA_API_KEY=your-cartesia-api-key

# Daily Configuration (required for local development)
DAILY_API_KEY=your-daily-api-key

# E2E Testing: External Room Injection
# Set these to have the agent join an existing room (instead of creating one)
# DAILY_ROOM_URL=https://your-domain.daily.co/room-name
# DAILY_ROOM_TOKEN=your-meeting-token

# Pipecat Cloud Configuration (for cloud deployment and E2E cloud tests)
# PIPECAT_CLOUD_API_KEY=your-pipecat-cloud-api-key
# PIPECAT_CLOUD_API_URL=https://api.pipecat.ai
