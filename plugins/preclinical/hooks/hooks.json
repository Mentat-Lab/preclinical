{
  "description": "Preclinical session hooks — health check on start.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/health-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
